# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_USER=worldmonitor
# Use a strong random password: openssl rand -hex 16
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=worldmonitor

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the browser.
# Set to your public domain once you have one.
# Example: CORS_ORIGINS=https://monitor.yourdomain.com
# For testing without a domain you can temporarily use: CORS_ORIGINS=*
# WARNING: Never use CORS_ORIGINS=* in a real production deployment — it
# disables cross-origin protection and allows any website to call your API.
CORS_ORIGINS=https://yourdomain.com

# ── Frontend API URL ───────────────────────────────────────────────────────────
# Leave as /api/v1 for VPS deployments where nginx proxies /api/ to the backend.
# Change to the full backend URL if frontend and backend are on separate domains.
VITE_API_URL=/api/v1

# ── Web server port ────────────────────────────────────────────────────────────
HTTP_PORT=80

# ── Email Notifications (optional) ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
# Gmail: use a 16-character App Password (requires 2FA enabled)
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=noreply@yourdomain.com

# ── Web Push Notifications (optional) ─────────────────────────────────────────
# Generate keys (run once):
#   pip install pywebpush
#   python -c "
#   from pywebpush import Vapid
#   v = Vapid(); v.generate_keys()
#   print('VAPID_PRIVATE_KEY =', v.private_key.serialize().decode())
#   print('VAPID_PUBLIC_KEY  =', v.public_key.serialize().decode())
#   "
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=admin@yourdomain.com

# ── WhatsApp (optional) ────────────────────────────────────────────────────────
WHATSAPP_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Data ingestion interval ────────────────────────────────────────────────────
INGESTION_INTERVAL_SECONDS=300
